# Cloudflare R2 public image URLs
# Example: https://pub-xxxxxxxx.r2.dev/latest/deck.jpg
VITE_DECK_CAM_URL="https://YOUR_PUBLIC_R2_URL/latest/deck.jpg"
VITE_BOW_CAM_URL="https://YOUR_PUBLIC_R2_URL/latest/bow.jpg"

# Refresh timing in milliseconds
VITE_DECK_CAM_REFRESH_MS=5000
VITE_BOW_CAM_REFRESH_MS=30000
